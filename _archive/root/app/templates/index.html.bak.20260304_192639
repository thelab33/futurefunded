{# ---------------------------------------------------------------------------
FutureFunded • Flagship — INDEX (DROP-IN REPLACEMENT)
Contracts:

* Doctype first
* Exactly ONE FF_CFG JSON payload (ffConfig) using tojson
* ffSelectors is raw JSON only (no Jinja inside the JSON)
* CSP-safe (nonce_attr) and overlay contracts preserved
  --------------------------------------------------------------------------- #}

{# ---- Stable build/version defaults (safe if not injected by Flask) ---- #}
{% set FF_BUILD_ID = (FF_BUILD_ID|default((config.get('FF_BUILD_ID') if config is mapping else ''), true)|default('dev', true))|string|trim %}
{% set FF_VERSION = (FF_VERSION|default((config.get('FF_VERSION') if config is mapping else ''), true)|default('dev', true))|string|trim %}
{% set _v = (asset_v|default(FF_ASSET_V|default(FF_BUILD_ID|default(FF_VERSION, true), true), true))|string|trim %}
{% if not _v %}{% set _v = '1' %}{% endif %}

{# ---- Macros (CSP nonce + formatting) ---- #}
{% macro nonce_attr() -%}
{%- set _n = (csp_nonce|default((g.csp_nonce if g is defined else ''), true))|string|trim -%}
{%- if _n -%}nonce="{{ _n|e }}"{%- endif -%}
{%- endmacro %}

{% macro money(v, symbol='$') -%}
{%- set _n = (v|default(0, true))|float -%}
{{- symbol -}}{{- '{:,.0f}'.format(_n) -}}
{%- endmacro %}

{# ---------------------------- ENV (ship-safe, injected-first) ---------------------------- #}
{% set _env_guess = (
ff_env
|default(ENV|default((config.get('ENV') if config is mapping else ''), true), true)
|default((config.get('FLASK_ENV') if config is mapping else ''), true)
|default((config.get('APP_ENV') if config is mapping else ''), true)
|default('development', true)
)|string|lower|trim %}

{% set ff_env = (ff_env|default(_env_guess, true))|string|lower|trim %}
{% if ff_env in ['production','prod','live'] %}
{% set ff_env = "production" %}
{% elif ff_env in ['testing','test'] %}
{% set ff_env = "testing" %}
{% else %}
{% set ff_env = "development" %}
{% endif %}
{% set _is_prod = ff_env == 'production' %}

{# ---------------------------- Public base URL (proxy-safe) ---------------------------- #}
{% set _public_base_raw = (
(ff_public_base_url|default('', true))
or (config.get('FF_PUBLIC_BASE_URL') if config is mapping else '')
or (config.get('PUBLIC_BASE_URL') if config is mapping else '')
or (request.url_root if request is defined else '')
)|string|trim %}

{% if _public_base_raw and _public_base_raw[-1] == '/' %}
{% set _public_base_raw = _public_base_raw[:-1] %}
{% endif %}
{% if _is_prod and _public_base_raw.startswith('http://') %}
{% set _public_base_raw = _public_base_raw|replace('http://','https://',1) %}
{% endif %}
{% if _is_prod and (_public_base_raw|lower is string) and ('localhost' in (_public_base_raw|lower) or '127.0.0.1' in (_public_base_raw|lower) or '[::1]' in (_public_base_raw|lower)) %}
{% set _public_base_raw = "[https://getfuturefunded.com](https://getfuturefunded.com)" %}
{% endif %}
{% if not _public_base_raw %}
{% set _public_base_raw = "[https://getfuturefunded.com](https://getfuturefunded.com)" %}
{% endif %}
{% set _public_base = _public_base_raw %}

{# ---------------------------- Canonical URL (uses public base) ---------------------------- #}
{% set _path = (request.path if request is defined else '/')|string %}
{% set canonical = (canonical_url|default((_public_base ~ _path), true))|string|trim %}
{% if canonical and canonical.startswith('http://') and _is_prod %}
{% set canonical = canonical|replace('http://','https://',1) %}
{% endif %}

{# ---------------------------- Stripe return URL (MUST be public-base safe) ---------------------------- #}
{% set _stripe_return = (stripe_return_url|default(canonical, true))|string|trim %}
{% if _stripe_return and _stripe_return.startswith('http://') and _is_prod %}
{% set _stripe_return = _stripe_return|replace('http://','https://',1) %}
{% endif %}
{% if _is_prod and ('localhost' in (_stripe_return|lower) or '127.0.0.1' in (_stripe_return|lower) or '[::1]' in (_stripe_return|lower)) %}
{% set _stripe_return = "[https://getfuturefunded.com/](https://getfuturefunded.com/)" %}
{% endif %}

{# ---------------------------- Smoke (non-prod utility) ---------------------------- #}
{% set _smoke_raw = (request.args.get('smoke') if request is defined else '') %}
{% set _smoke = (_smoke_raw is boolean and _smoke_raw) or (_smoke_raw|string|lower|trim in ['1','true','yes','on']) %}

{# ---------------------------- Org / Campaign text ---------------------------- #}
{% set _org_name = (org_name|default((team.get('team_name') if team is mapping else 'Connect ATX Elite'), true))|string|trim %}
{% if not _org_name %}{% set _org_name = "Connect ATX Elite" %}{% endif %}

{% set _location = (campaign_location|default(org_location, true)|default((team.get('location') if team is mapping else 'Austin, TX'), true))|string|trim %}
{% if not _location %}{% set _location = "Austin, TX" %}{% endif %}

{% set _organizer_label = (organizer_label|default(_org_name ~ ' coaching staff', true))|string|trim %}
{% set _organizer_email = (organizer_email|default(contact_email, true)|default(support_email, true)|default('[support@getfuturefunded.com](mailto:support@getfuturefunded.com)', true))|string|trim %}

{% set _campaign_headline = (campaign_headline|default('Fuel the season. Fund the future.', true))|string|trim %}
{% if not _campaign_headline %}{% set _campaign_headline = "Fuel the season. Fund the future." %}{% endif %}

{% set _campaign_subhead = (campaign_subhead|default('Back the athletes of', true))|string|trim %}
{% if not _campaign_subhead %}{% set _campaign_subhead = "Back the athletes of" %}{% endif %}

{% set _campaign_name = (campaign_name|default(_org_name, true))|string|trim %}
{% if not _campaign_name %}{% set _campaign_name = _org_name %}{% endif %}
{% if _campaign_name|length > 48 %}{% set _campaign_name = _org_name %}{% endif %}

{% set _campaign_tagline = (campaign_tagline|default('Travel, gym time, gear, and tournament fees — your gift keeps them playing.', true))|string|trim %}
{% if not _campaign_tagline %}{% set _campaign_tagline = "Travel, gym time, gear, and tournament fees — your gift keeps them playing." %}{% endif %}

{% set _proof_blurb = (_proof_blurb|default(proof_blurb|default('Your support keeps training, travel, and tournament reps funded — with fast, secure checkout and instant email receipts.', true), true))|string|trim %}
{% set _policy_blurb = (_policy_blurb|default(policy_blurb|default('Questions, corrections, or receipts: email the organizer address listed on this page. Refunds and disputes follow the payment processor policy and organizer response.', true), true))|string|trim %}

{# ---------------------------- Logos / Platform ---------------------------- #}
{% set _org_logo = (org_logo|default(url_for('static', filename='images/logo.webp') ~ '?v=' ~ _v, true))|string|trim %}
{% set _org_logo_svg = (org_logo_svg|default(url_for('static', filename='images/fundchamps-fc.svg') ~ '?v=' ~ _v, true))|string|trim %}

{% set _ff_home = (ff_home|default('[https://getfuturefunded.com](https://getfuturefunded.com)', true))|string|trim %}
{% set _ff_home_noslash = (_ff_home[:-1] if _ff_home and _ff_home[-1] == '/' else _ff_home) %}
{% set _ff_create = (ff_create_url|default(_ff_home_noslash ~ '/create', true))|string|trim %}

{% set _ff_logo = (ff_logo|default(url_for('static', filename='images/fundchamps-fc.svg') ~ '?v=' ~ _v, true))|string|trim %}
{% set _platform_logo = (platform_logo|default(_ff_logo, true))|string|trim %}

{# ---------------------------- Legal / Support ---------------------------- #}
{% set _email = (_organizer_email)|string|trim %}
{% set _announce = (announcement_text|default(announcement|default('', true), true))|string|trim %}
{% set announcement_text = (_announce)|string|trim %}
{% set _terms_url = (terms_url|default('#terms', true))|string|trim %}
{% set _privacy_url = (privacy_url|default('#privacy', true))|string|trim %}

{# ---------------------------- Payments (keys + endpoints) ---------------------------- #}
{% set _stripe_pk = (
stripe_pk|default('', true)
or STRIPE_PUBLISHABLE_KEY|default('', true)
or STRIPE_PUBLIC_KEY|default('', true)
or FF_STRIPE_PUBLISHABLE_KEY|default('', true)
or (config.get('STRIPE_PUBLISHABLE_KEY') if config is mapping else '')
or (config.get('STRIPE_PUBLIC_KEY') if config is mapping else '')
or (config.get('FF_STRIPE_PUBLISHABLE_KEY') if config is mapping else '')
)|string|trim %}
{% if _stripe_pk|lower in ['none','null'] %}{% set _stripe_pk = "" %}{% endif %}

{% set _pp = (
paypal_client_id|default('', true)
or PAYPAL_CLIENT_ID|default('', true)
or FF_PAYPAL_CLIENT_ID|default('', true)
or (config.get('PAYPAL_CLIENT_ID') if config is mapping else '')
or (config.get('FF_PAYPAL_CLIENT_ID') if config is mapping else '')
)|string|trim %}
{% set _pp_sanitized = (_pp|string|trim) if (_pp|string|trim not in ['None','null','']) else '' %}

{% set _stripe_intent_endpoint = (stripe_intent_endpoint|default('/payments/stripe/intent', true))|string|trim %}
{% set _paypal_create_endpoint = (paypal_create_endpoint|default('/payments/paypal/order', true))|string|trim %}
{% set _paypal_capture_endpoint = (paypal_capture_endpoint|default('/payments/paypal/capture', true))|string|trim %}
{% set _payments_config_endpoint = (payments_config_endpoint|default('/payments/config', true))|string|trim %}
{% set _payments_health_endpoint = (payments_health_endpoint|default('/payments/health', true))|string|trim %}
{% set _status_endpoint = (status_endpoint|default('/api/status', true))|string|trim %}
{% set _currency = (currency|default('USD', true))|string|trim %}
{% set _deadline_iso = (fundraiser_deadline_iso|default('2026-02-28T23:59:59-06:00', true))|string|trim %}
{% set _deadline_fallback = (fundraiser_deadline_human|default((_deadline_iso[:10] if _deadline_iso else ''), true))|string|trim %}

{# ---------------------------- Feature flags / booleans ---------------------------- #}
{% set _cfx_raw = (cover_fees_exact|default(COVER_FEES_EXACT|default(false, true), true)) %}
{% set _rem_raw = (require_email|default(REQUIRE_EMAIL|default(true, true), true)) %}
{% set _cover_fees_exact = (_cfx_raw is boolean and _cfx_raw) or (_cfx_raw|string|lower|trim in ['1','true','yes','on']) %}
{% set _require_email = (_rem_raw is boolean and _rem_raw) or (_rem_raw|string|lower|trim in ['1','true','yes','on']) %}

{% set _wl_raw = WHITELABEL_MODE|default(whitelabel|default(false, true), true) %}
{% set _whitelabel_mode = (_wl_raw is boolean and _wl_raw) or (_wl_raw|string|lower|trim in ['1','true','yes','on']) %}
{% set _whitelabel = _whitelabel_mode %}

{# ---------------------------- Theme / SEO ---------------------------- #}
{% set theme_color_final = (theme_color|default((team.get('theme_color') if team is mapping else '#f97316'), true)|default('#f97316', true))|string|trim %}
{% set theme_color_light_final = (theme_color_light|default(theme_color_final, true))|string|trim %}
{% set theme_color_dark_final = (theme_color_dark|default('#0b0f17', true))|string|trim %}

{% set page_title_final = (page_title|default(_campaign_name ~ ' • Fundraiser • ' ~ _org_name, true))|string|trim %}
{% set page_desc_final = (page_description|default('Support ' ~ _campaign_name ~ ' with a fast, secure donation. Instant receipt. No account required.', true))|string|trim %}
{% set og_title_final = (og_title|default(page_title_final, true))|string|trim %}
{% set og_desc_final = (og_description|default(_campaign_tagline, true))|string|trim %}
{% set og_alt_final = (og_image_alt|default('Fundraiser preview', true))|string|trim %}

{% set _og_webp_path = url_for('static', filename='images/og_connect_atx_elite.webp') %}
{% set _og_jpg_path = url_for('static', filename='images/og.jpg') %}
{% set og_webp = (og_image_webp|default((_public_base ~ _og_webp_path ~ '?v=' ~ _v), true))|string|trim %}
{% set og_jpg = (og_image_jpg|default((_public_base ~ _og_jpg_path ~ '?v=' ~ _v), true))|string|trim %}

{% set _year = (year|default(current_year|default(2026, true), true))|int %}

{# ---------------- DATA TRUTH POLICY (single source of truth) ---------------- #}
{% set _mode_raw = (ff_data_mode|default('', true))|string|lower|trim %}
{% if _mode_raw not in ['live','demo','preview'] %}
{% set _mode_raw = ('live' if _is_prod else 'demo') %}
{% endif %}
{% if (not _is_prod) and request is defined and request.args.get('mode') %}
{% set _qmode = (request.args.get('mode')|string|lower|trim) %}
{% if _qmode in ['live','demo','preview'] %}
{% set _mode_raw = _qmode %}
{% endif %}
{% endif %}
{% set ff_data_mode = _mode_raw %}

{# Verified totals hard guard #}
{% set _tv_raw = (ff_totals_verified|default(fundraiser_totals_verified|default(false, true), true)) %}
{% set _totals_verified = (_tv_raw is boolean and _tv_raw) or (_tv_raw|string|lower|trim in ['1','true','yes','on']) %}
{% if (not _is_prod) and request is defined and request.args.get('totals_verified') %}
{% set _tvq = (request.args.get('totals_verified')|string|lower|trim) %}
{% if _tvq in ['1','true','yes','on'] %}
{% set _totals_verified = true %}
{% endif %}
{% endif %}

{% set _allow_live_totals_raw = (
ff_allow_live_totals
|default(FF_ALLOW_LIVE_TOTALS|default(false, true), true)
|default((config.get('FF_ALLOW_LIVE_TOTALS') if config is mapping else false), true)
) %}
{% set _allow_live_totals = (_allow_live_totals_raw is boolean and _allow_live_totals_raw) or (_allow_live_totals_raw|string|lower|trim in ['1','true','yes','on']) %}

{% if _is_prod and ff_data_mode == 'live' and not _allow_live_totals %}
{% set _totals_verified = false %}
{% endif %}

{% set _goal_backend = (fundraiser_goal|default(goal|default(0, true), true))|float %}
{% set _raised_backend = (amount_raised|default(raised|default(0, true), true))|float %}

{# ---------------------------- Effective totals (privacy-safe, deterministic) ---------------------------- #}
{% set nsTotals = namespace(goal=_goal_backend, raised=_raised_backend, source='backend') %}
{% if ff_data_mode == 'live' %}
{% if _totals_verified %}
{% set nsTotals.source = "verified" %}
{% else %}
{% set nsTotals.goal = 0 %}
{% set nsTotals.raised = 0 %}
{% set nsTotals.source = "pending" %}
{% endif %}
{% else %}
{% set nsTotals.source = "preview" %}
{% endif %}

{% set _goal_effective = nsTotals.goal %}
{% set _raised_effective = nsTotals.raised %}
{% set _totals_source_effective = nsTotals.source %}

{# Team raised sum (best-effort for smoke/debug, safe default) #}
{% set nsSum = namespace(v=0.0) %}
{% if FF_CFG is mapping and (FF_CFG.get('teams') is iterable) %}
{% for t in (FF_CFG.get('teams') or []) %}
{% set nsSum.v = nsSum.v + ((t.raised|default(0, true))|float) %}
{% endfor %}
{% endif %}
{% set _teams_sum_raised = nsSum.v %}

{# Progress percent (0..100 int) #}
{% set _pct_raw = 0.0 %}
{% if _goal_effective|float > 0 %}
{% set _pct_raw = (_raised_effective|float / _goal_effective|float) * 100.0 %}
{% endif %}
{% set _pct_i = (_pct_raw|round(0, 'floor')|int) %}
{% if _pct_i < 0 %}{% set _pct_i = 0 %}{% endif %}
{% if _pct_i > 100 %}{% set _pct_i = 100 %}{% endif %}

{# Content config objects #}
{% set FF_CFG = FF_CFG|default({}, true) %}
{% if FF_CFG is not mapping %}{% set FF_CFG = {} %}{% endif %}

{% set FF_GALLERY = gallery|default({
"enabled": true,
"items": [
{"src": (url_for("static", filename="images/connect-atx-team.jpg") ~ "?v=" ~ _v), "alt": "Connect ATX Elite", "caption": "Connect ATX Elite"},
{"src": (url_for("static", filename="images/7thGold.jpg") ~ "?v=" ~ _v), "alt": "7th Grade Gold", "caption": "7th Grade Gold"},
{"src": (url_for("static", filename="images/7thBlack.png") ~ "?v=" ~ _v), "alt": "7th Grade Black", "caption": "7th Grade Black"},
{"src": (url_for("static", filename="images/8thGold.jpg") ~ "?v=" ~ _v), "alt": "8th Grade Gold", "caption": "8th Grade Gold"},
{"src": (url_for("static", filename="images/connect-atx-team_3.jpg") ~ "?v=" ~ _v), "alt": "8th Grade Black", "caption": "8th Grade Black"}
]
}, true) %}

