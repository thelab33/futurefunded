<html class="ff-root"
      lang="en"
      dir="ltr"
      data-density="{{ density|default('compact', true) |string|trim|e }}"
      data-ff-brand="{{ brand_key|default('futurefunded', true) |string|trim|e }}"
      data-ff-build="{{ FF_BUILD_ID|e }}"
      data-ff-version="{{ FF_VERSION|e }}"
      data-theme="{{ theme|default('light', true) |string|trim|e }}">

<head>
  <!-- Core -->
  <meta charset="utf-8" />
  <meta http-equiv="x-ua-compatible" content="ie=edge" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,maximum-scale=5" />
  <meta name="format-detection" content="telephone=no,date=no,address=no,email=no" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="color-scheme" content="light dark" />
  <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="generator" content="FutureFunded Flagship" />

  <!-- Title / Description -->

  <title>{{ page_title_final|e }}</title>
  <meta name="description" content="{{ page_desc_final|e }}" />

  <!-- Canonical -->

{% if canonical %} <link rel="canonical" href="{{ canonical|e }}" /> <meta property="og:url" content="{{ canonical|e }}" /> <meta name="twitter:url" content="{{ canonical|e }}" />
{% endif %}

  <!-- Open Graph -->

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="{{ _org_name|e }}" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:title" content="{{ og_title_final|e }}" />
  <meta property="og:description" content="{{ og_desc_final|e }}" />

  <!-- Twitter -->

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ og_title_final|e }}" />
  <meta name="twitter:description" content="{{ og_desc_final|e }}" />
  <meta name="twitter:image" content="{{ og_jpg|e }}" />
  <meta name="twitter:image:alt" content="{{ og_alt_final|e }}" />

  <!-- OG Images (jpg + webp) -->

  <meta property="og:image" content="{{ og_jpg|e }}" />
  <meta property="og:image:secure_url" content="{{ og_jpg|e }}" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:alt" content="{{ og_alt_final|e }}" />
  <meta property="og:image" content="{{ og_webp|e }}" />
  <meta property="og:image:secure_url" content="{{ og_webp|e }}" />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:image:alt" content="{{ og_alt_final|e }}" />

  <!-- Theme / App -->

  <meta name="theme-color" media="(prefers-color-scheme: light)" content="{{ theme_color_light_final|e }}" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="{{ theme_color_dark_final|e }}" />
  <meta name="application-name" content="{{ _org_name|e }}" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="{{ _org_name|e }}" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <!-- Icons -->

  <link rel="icon" sizes="any" href="{{ url_for('static', filename='images/favicon.ico') }}?v={{ _v }}" />
  <link rel="icon" type="image/png" sizes="32x32" href="{{ url_for('static', filename='images/icon-32.png') }}?v={{ _v }}" />
  <link rel="icon" type="image/png" sizes="192x192" href="{{ url_for('static', filename='images/icon-192.png') }}?v={{ _v }}" />
  <link rel="apple-touch-icon" href="{{ url_for('static', filename='images/apple-touch-icon.png') }}?v={{ _v }}" />
  <link rel="mask-icon" color="{{ theme_color_final|e }}" href="{{ url_for('static', filename='images/safari-pinned-tab.svg') }}?v={{ _v }}" />
  <link rel="manifest" href="{{ url_for('static', filename='manifest.webmanifest') }}?v={{ _v }}" />

  <!-- Preconnect (safe wins) -->

  <link rel="preconnect" href="https://js.stripe.com" crossorigin />
  <link rel="dns-prefetch" href="https://js.stripe.com" />

  <!-- Preload critical image -->

  <link rel="preload" as="image" fetchpriority="high" href="{{ _org_logo|e }}" />

  <!-- CSRF (if available) -->

{% if csrf_token is defined %} <meta name="csrf-token" content="{{ csrf_token() }}" />
{% endif %}

  <!-- FF meta mirror -->

{% set _ff_meta = {
'env': ff_env,
'data-mode': ff_data_mode,
'totals-verified': ('true' if _totals_verified else 'false'),
'version': FF_VERSION,
'build-id': FF_BUILD_ID,
'asset-v': _v,
'stripe-pk': _stripe_pk|default('', true)|string|trim,
'stripe-intent-endpoint': _stripe_intent_endpoint|default('', true)|string|trim,
'stripe-return-url': _stripe_return|default('', true)|string|trim,
'stripe-js': '[https://js.stripe.com/v3/](https://js.stripe.com/v3/)',
'paypal-client-id': _pp_sanitized|default('', true)|string|trim,
'paypal-currency': (paypal_currency|default('USD', true))|string|trim,
'paypal-intent': (paypal_intent|default('capture', true))|string|trim,
'paypal-create-endpoint': _paypal_create_endpoint|default('', true)|string|trim,
'paypal-capture-endpoint': _paypal_capture_endpoint|default('', true)|string|trim,
'payments-config-endpoint': _payments_config_endpoint|default('', true)|string|trim,
'payments-health-endpoint': _payments_health_endpoint|default('', true)|string|trim,
'status-endpoint': _status_endpoint|default('', true)|string|trim,
