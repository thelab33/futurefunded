# --------------------------------------------------
# FutureFunded — repo hygiene
# --------------------------------------------------

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.python-version
.coverage
.coverage.*
htmlcov/

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
.eslintcache
*.tsbuildinfo

# Playwright / test outputs
playwright-report/
test-results/
blob-report/
coverage/
.nyc_output/

# Local QA / validation / generated reports
.logs/
artifacts/
tools/.artifacts/
.htmlvalidate.rendered.json
getfuturefunded.com_*.report.html
local.html
prod.html

# Local databases / runtime state
instance/
app/data/*.db
app/data/*.sqlite*
*.db
*.sqlite*

# Environment files
.env
.env.*
!.env.example

# Backup / patch / restore debris
*.bak
*.bak_*
*.bak-*
*.bad-*
*.orig
*.rej
*.tmp
*.tmp_restore
*.after_patching_backup
*.withoverrides
*.bak_loader
*.bak_djlint
*.bak_ff*
*.bak_cookie_secure

# Project-specific backup clutter
app/static/css/*.bak*
app/static/js/*.bak*
app/templates/*.bak*
app/static/img/_bak_*/

# Historical backup folders
app/templates_backup/
app/static/css_backup/
app/static/js/extracted/

# Local scratch / one-off outputs
nohup.out

# Editor / OS noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

.supervisord.pid
.supervisor.sock
tmp/restart.txt
.logs/

# Windows-path junk accidentally created inside repo under WSL
C:\\Users\\*

# Windows download metadata
*:Zone.Identifier
